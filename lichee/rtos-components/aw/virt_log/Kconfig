	int "virt log buffer size(unit:Kb)"
	default 4

config COMMAND_DMESG
    bool "Dmesg Command to show virt log buffer"
	default n

config ULTRA_STANDBY_VIRT_LOG
	bool "enable virt log in ultra standby"
	default n
endif
