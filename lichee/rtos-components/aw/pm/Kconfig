
menuconfig COMPONENTS_PM
    bool "PowerManager Support"
    default n
    help
      Support standby and hibernation mode.

if COMPONENTS_PM
if COMPONENTS_AMP_PM || ARCH_SUN20IW2P1
choice COMPONENTS_PM_CORE
    prompt "Select core"
    default COMPONENTS_PM_CORE_M33   if ARCH_ARM_ARMV8M
    default COMPONENTS_PM_CORE_RISCV if ARCH_RISCV_RV64
    default COMPONENTS_PM_CORE_DSP   if ARCH_DSP
    help
      This option determines which core the PM run on.
      Usually used to divide the interaction between cores in the PM process.

    config COMPONENTS_PM_CORE_M33
        bool "M33"
        help
          the code for m33

    config COMPONENTS_PM_CORE_DSP
        bool "DSP"
        help
          the code for dsp

    config COMPONENTS_PM_CORE_RISCV
        bool "RISCV"
        help
          the code for riscv
endchoice
endif

menuconfig COMPONENTS_PM_WAKESRC
    bool "List of wakeup source types"
    default y
    depends on ARCH_SUN20IW2P1
    help
	List of wakesrc on the core.
	Some wakeup sources may need to register with the specific core.
	It is only used to detemine whether it is a wakeup source for the the driver that needs it.
	Configuration is n does not mean the wakesrc is not supported.

if COMPONENTS_PM_WAKESRC
config PM_WAKESRC_WUPIO
    bool "WUPIO wakesrc"
    default y
    help
      WUPIO wakesrc

config PM_WAKESRC_WUPTIMER
    bool "WUPTIMER wakesrc"
    default y
    help
      WUPTIMER wakesrc

config PM_WAKESRC_ALARM
    bool "RTC  Alarm wakesrc"
    default y
    help
      RTC alarm wakesrc

config PM_WAKESRC_LPUART
    bool "LPUART wakesrc"
    default n
    help
      LPUART wakesrc

config PM_WAKESRC_GPADC
    bool "GPADC wakesrc"
    default n
    help
      GPADC wakesrc

config PM_WAKESRC_MAD
    bool "MAD wakesrc"
    default n
    help
      MAD wakesrc

config PM_WAKESRC_WLAN
    bool "WLAN wakesrc"
    default n
    help
       WLAN wakesrc

config PM_WAKESRC_BLE
    bool "BLE wakesrc"
    default n
    help
       BLE wakesrc

config PM_WAKESRC_GPIO
    bool "GPIO wakesrc"
    default n
    help
       GPIO wakesrc
endif

comment "Special Config"
config ARCH_PM_FIRMWARE_BASE
    hex "PM Firmware's space base"
    default 0x02000000
    #depends on COMPONENTS_PM_CORE_M33
    help
      The space must be placed on SRAM.
      This parameter takes effect only after
      COMPONENTS_PM_CORE_M33 is enabled

config ARCH_PM_FIRMWARE_SIZE
    hex "PM Firmware's space size"
    default 0x21c00
    #depends on COMPONENTS_PM_CORE_M33
    help
      The recommended value is not less than 64K.

config RTOS_FW_RESERVED_MEM_ADDR
    hex "Rtos firmware reserved memory address"
    default "0x81444000"
    help
      Rtos firmware reserved memory address

config DRAM_POWER_OPEN_DURATION_US
    int "Dram power open dration of us"
    default 500
    help
      Set dram power open duration, because dcdc open will waste time

config PM_SIMULATED_RUNNING
    bool "Simulated on FPGA"
    default n
    help
      Simulates a running environment on the FPGA

config PM_SUBSYS_RISCV_SUPPORT
    bool "support riscv subsys"
    default y
    depends on COMPONENTS_PM_CORE_M33
    help
      Enable riscv subsys support

config PM_SUBSYS_DSP_SUPPORT
    bool "support dsp subsys"
    default n
    depends on COMPONENTS_PM_CORE_M33
    help
      Enable dsp subsys support

config COMPONENTS_PM_TEST_TOOLS
    bool "PM test tools"
    default n
    depends on COMPONENTS_PM
    help
      Enable pm test tools, including pm stress, recording sign and etc.

choice STANDBY_LOAD_STORAGE_TYPE
	prompt "Select standby load storage type"
    default PM_LOAD_STORAGE_TYPE_SPINOR
    depends on COMPONENTS_PM
	help
	  Select storage type which standby bin will load pm boot and rtos.

	config PM_LOAD_STORAGE_TYPE_SPINOR
	bool "SPINOR"
	select COMPONENTS_AW_FLASH_READ
	select COMPONENTS_AW_FLASH_READ_SPINOR
	help
	  Type for spinor.

	config PM_LOAD_STORAGE_TYPE_SPINAND
	bool "SPINAND"
	help
	  Type for spinand.

	config PM_LOAD_STORAGE_TYPE_MMC
	bool "MMC"
	help
	  Type for mmc.
endchoice
config PM_STANDBY_MEMORY
    bool "pm_standby_memory"
    default n
    depends on COMPONENTS_PM
    help
      Enable standby memory manager

config PM_TIME_RECORD
    bool "pm_time_record"
    default n
    depends on COMPONENTS_PM
    help
      Enable pm time record debug

config PM_TIME_RECORD_PLUS
    bool "pm_time_record_plus"
    default n
    depends on PM_TIME_RECORD
    help
      Enable pm time record debug, which record actions start&end moment in order.

config PM_HEAP_RECORD
    bool "pm_heap_record"
    default n
    depends on COMPONENTS_PM
    help
      Enable pm heap record debug

config PM_DISABLE_ALL_LOG
    bool "pm_disable_all_log"
    default n
    depends on COMPONENTS_PM
    help
      Disable all log in suspend and resume

config PM_HEAP_RETAIN
    bool "pm_heap_retain"
    default n
    depends on COMPONENTS_PM
    help
      calculate heap retain space

config PM_DEBUG_BACKTRACE_PERIODICALLY
    bool "pm debug backtrace periodically"
    default n
    depends on COMPONENTS_PM
    help
    	Periodically backtrace the pm process.

config PM_RECORD_STAGE_BY_DEFAULT
    bool "pm record stage by default"
    default n
    depends on COMPONENTS_PM
    help
    	pm record stage to specific regs by default

