menuconfig COMPONENTS_AMP_APP
	bool "AMP Application"
	default n
	help
	  Enable some applications which is used on AMP situation.
	  Some of them is based on OpenAMP framework.

if COMPONENTS_AMP_APP

menuconfig COMPONENTS_AMP_HW_WATCHDOG
	bool "AMP Hardware Watchdog"
	default n
	help
	  When we use the hardware watchdog on AMP, we don't need to init watchdog.
	  We only need to setup the timeout of watchdog timer and feed watchdog.
	  If you want feed watchdog and setup the timeout on your private code,
	  you need to disable this configuration.

if COMPONENTS_AMP_HW_WATCHDOG

config AMP_HW_WATCHDOG_TIMEOUT
	int "The Timeout of AMP Hardware Watchdog(unit: second)"
	default 2

config AMP_HW_WATCHDOG_FEED_INTERVAL
	int "The Interval to Feed AMP Hardware Watchdog(unit: ms)"
	default 100

config AMP_HW_WATCHDOG_THREAD_PRIORITY
	int "The Thread Priority to Feed AMP Hardware Watchdog"
	default 31

endif #COMPONENTS_AMP_HW_WATCHDOG

menuconfig COMPONENTS_AMP_USER_MEMORY
	bool "AMP User Memory"
	default n
	select AMP_USER_MEMORY_0
	help
	  AMP User Memory for remoteproc(slave).
	  Currently it only support loading custom data form partition.

if COMPONENTS_AMP_USER_MEMORY

config DUMP_ALL_AMP_USER_MEMORY_INFO
	bool "Dump All AMP User Memory Information after System Starting"
	default n

config AMP_USER_MEMORY_DT_NODE_NAME_PREFIX
	string "AMP User Memory Device Tree Node Name Prefix"
	default "e907_user_mem" if ARCH_RISCV
	default "dsp_user_mem" if ARCH_DSP

config AMP_USER_MEMORY_0
	bool "Enable AMP User Memory 0"
	default y

config AMP_USER_MEMORY_1
	bool "Enable AMP User Memory 1"
	default n

config AMP_USER_MEMORY_2
	bool "Enable AMP User Memory 2"
	default n

config AMP_USER_MEMORY_3
	bool "Enable AMP User Memory 3"
	default n

endif #COMPONENTS_AMP_USER_MEMORY

