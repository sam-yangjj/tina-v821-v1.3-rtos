menuconfig COMPONENTS_AMP_TIMESTAMP
	bool "AMP Timestamp"
	default n
	select AMP_TS_DEV_0
	help
	  Allwinner AMP timestamp component, it provide timestamp
	  with same timebase on AMP situation.

if COMPONENTS_AMP_TIMESTAMP

config AMP_TS_DEV_0
	bool "Enable AMP Timestamp Device 0"
	default y

if AMP_TS_DEV_0

config AMP_TS_DEV_0_COUNTER_REG_ADDR
	hex "AMP Timestamp Device 0 Counter Register Base Address"
	default 0

config AMP_TS_DEV_0_COUNT_FREQ
	int "AMP Timestamp Device 0 Count Frequency(unit: Hz)"
	default 24000000

config AMP_TS_DEV_0_COUNTER_TYPE
	int "AMP Timestamp Device 0 Counter Type"
	default 0

config AMP_TS_TEST_CMD
	bool "AMP Timestamp Test cmd"
	default n

endif

endif #COMPONENTS_AMP_TIMESTAMP

endif #COMPONENTS_AMP_APP

