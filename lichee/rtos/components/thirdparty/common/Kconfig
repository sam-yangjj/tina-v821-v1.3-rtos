menu "common component"

config COMPONENT_COMMON
    bool "printf support"
    default y

choice
    prompt "printf selection"
    default NEWLIBC_PRINTF

    config NEWLIBC_PRINTF
        bool "newlibc printf"

    config TINY_PRINTF
        bool "tiny printf"

endchoice

config PRINTF_WITH_TIMESTAMP
    bool "printf with timestamp"
    depends on TINY_PRINTF
    default n

config CUSTOM_VSPRINTF
    bool "custom vsprintf"
    default n

endmenu
