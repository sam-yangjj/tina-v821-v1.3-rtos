menu "GPADC Devices"

config DRIVERS_GPADC
    bool "enable gpadc driver"
    depends on ARCH_SUN8IW18P1 || ARCH_SUN8IW19 || ARCH_SUN20IW1 || ARCH_SUN8IW20 || ARCH_SUN20IW2 || ARCH_SUN20IW3 || ARCH_SUN300IW1
        default y

config DRIVERS_POWER_PROTECT
    bool "enable power protect driver"
    depends on DRIVERS_GPADC
        default n

config PM_NEED_GPADC
    bool "Need gpadc when pm period"
    depends on DRIVERS_GPADC
        default n

config HAL_TEST_GPADC
    bool "enable gpadc hal APIs test command"
    depends on DRIVERS_GPADC
        default n

endmenu
